{
  "name": "competehub-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "e2e:install": "playwright install chromium",
    "preview": "vite preview",
    "lint": "vue-tsc --noEmit",
    "seed:e2e": "bash ../../scripts/agent-env.sh uv run --project ../api flask --app competehub_api.app:create_e2e_app seed-e2e --reset",
    "test:e2e": "npm run seed:e2e && playwright test",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@ant-design/icons-vue": "^7.0.1",
    "ant-design-vue": "^4.2.6",
    "axios": "^1.13.0",
    "pinia": "^3.0.0",
    "vue": "^3.5.0",
    "vue-router": "^4.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tsconfig/node22": "^22.0.0",
    "@types/node": "^24.0.0",
    "@vitejs/plugin-vue": "^6.0.0",
    "@vue/tsconfig": "^0.8.0",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vue-tsc": "^3.0.0"
  }
}
