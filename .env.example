COMPETEHUB_ENV=development
SECRET_KEY=change-me-in-local-env
DATABASE_URL=postgresql+psycopg://competehub:competehub@localhost:5432/competehub
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
# Reminder worker bounds: dispatch batch 1-1000, attempts 1-10, backoff base 1-3600s.
REMINDER_DISPATCH_BATCH_SIZE=100
REMINDER_MAX_ATTEMPTS=3
REMINDER_RETRY_BASE_SECONDS=60
# Beat cadence: dispatch/requeue 1-3600s; retention cleanup 60-604800s.
REMINDER_DISPATCH_INTERVAL_SECONDS=15
REMINDER_REQUEUE_INTERVAL_SECONDS=30
MESSAGE_RETENTION_INTERVAL_SECONDS=86400
# Cleanup batch is tunable (1-5000); the message retention duration is fixed at 365 days.
MESSAGE_RETENTION_BATCH_SIZE=500
PUBLIC_EMAIL_REGISTRATION_ENABLED=false
# EMAIL_VERIFICATION_SENDER_DSN=smtp://username:password@smtp.example.edu:587?from=CompeteHub%20%3Cnoreply%40example.edu%3E&starttls=true
VITE_API_BASE_URL=http://localhost:5000/api/v1
